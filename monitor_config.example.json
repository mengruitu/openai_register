{
  "_comment": "A-only monitor 配置示例。以 _ 开头的字段为注释，会被忽略。",
  "_usage": [
    "将本文件复制为 monitor_config.json 并修改其中的值即可。",
    "当前巡检只维护 A 目录：不做删号、不查额度、不维护 B 目录。",
    "不要再使用旧版字段或参数：pool_min_count / usage_threshold。",
    "命令行参数优先于配置文件。配置文件中未设置的项使用代码默认值。"
  ],

  "_section_paths": "===== A 目录配置 =====",
  "active_token_dir": "/data/openai_register/auths",

  "_section_thresholds": "===== A 目录目标 =====",
  "active_min_count": 20,

  "_section_intervals": "===== 时间间隔（秒） =====",
  "monitor_interval": 900,
  "dingtalk_summary_interval": 10800,
  "sleep_min": 20,
  "sleep_max": 40,
  "failure_sleep_seconds": 20,

  "_section_register": "===== 注册配置（默认放慢） =====",
  "mail_provider": "cfmail",
  "register_batch_size": 1,
  "register_openai_concurrency": 1,
  "register_start_delay_seconds": 8.0,

  "_section_register_only_r2": "===== register-only 收尾上传到 Cloudflare R2 =====",
  "_r2_usage": [
    "仅在 --register-only 模式下生效；monitor / monitor-once 不会触发。",
    "register-only 所有线程自然结束后，会把 token_dir 下现存的全部 JSON 逐个上传到 R2。",
    "只有当这一批 JSON 全部上传成功后，才会自动删除 token_dir 里的本地 JSON。"
  ],
  "r2_enabled": false,
  "r2_account_id": "",
  "r2_bucket": "",
  "r2_access_key_id": "",
  "r2_secret_access_key": "",
  "r2_prefix": "openai-register",
  "r2_retry_count": 2,
  "r2_retry_delay_seconds": 3.0,

  "_section_cfmail": "===== temp-mail 兼容配置 =====",
  "cfmail_profile": "auto",
  "cfmail_config": "/data/openai_register/cfmail_accounts.json",
  "cfmail_fail_threshold": 3,
  "cfmail_cooldown_seconds": 300,

  "_section_notify": "===== 通知配置 =====",
  "dingtalk_webhook": "",
  "dingtalk_fallback_interval": 900,

  "_section_proxy": "===== 代理配置 =====",
  "proxy": "",
  "proxy_api_url": "",
  "proxy_api_scheme": "http",
  "proxy_pool_enabled": false,
  "proxy_pool_consumer_ttl_seconds": 120,
  "proxy_pool_heartbeat_interval_seconds": 15,
  "proxy_pool_state_path": "/data/openai_register/state/proxy_pool.json",
  "proxy_pool_consumers_path": "/data/openai_register/state/proxy_pool_consumers.json",
  "proxy_pool_target_multiplier": 2,

  "_section_flags": "===== 开关（true/false） =====",
  "monitor": true,
  "auto_continue_non_us": true
}
